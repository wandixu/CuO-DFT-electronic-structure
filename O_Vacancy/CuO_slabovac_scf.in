&control
  calculation='scf',
  prefix='CuO_111_slab_Ovac',
  outdir='./tmp',
  pseudo_dir='../SSSP'
/
&system
  ibrav=0,
  nat=31,
  ntyp=2,
  ecutwfc=90,
  ecutrho=720,
  occupations='smearing',
  smearing='mp',
  degauss=0.02,
  nspin = 2,
  starting_magnetization(1) = 0.5,   ! Cu（假设 type 1 是 Cu）
  starting_magnetization(2) = 0.0,   ! O
/
&electrons
  conv_thr=1.0d-8
  mixing_beta = 0.3,
  electron_maxstep = 200,
/

