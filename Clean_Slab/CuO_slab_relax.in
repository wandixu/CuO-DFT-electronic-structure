&control
  calculation = 'relax',
  prefix      = 'CuO_111_slab',
  outdir      = './tmp',
  pseudo_dir  = './SSSP',
  nstep       = 200,
/

&system
  ibrav     = 0,
  nat       = 32,
  ntyp      = 2,
  ecutwfc   = 60,
  ecutrho   = 480,
  occupations = 'smearing',
  smearing    = 'mp',
  degauss     = 0.02,
/

&electrons
  conv_thr    = 1.0d-6,
  mixing_beta = 0.3,
  electron_maxstep = 200,
/

&ions
  ion_dynamics = 'bfgs',
/

